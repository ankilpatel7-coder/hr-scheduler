// Shiftwork v12 schema — multi-tenant + payroll
// Changes vs v11:
//   - New Tenant model. Every tenant-scoped model gets `tenantId` FK.
//   - User.superAdmin boolean. SUPER_ADMIN can manage tenants; tenant-scoped users have superAdmin=false.
//   - SUPER_ADMIN users have tenantId=null (they don't belong to any single tenant).
//   - User gains W-4 / payroll fields.
//   - New PayPeriod, PayStub models for payroll generation.
//   - All existing relations preserved; new tenantId added to every relevant model.
//
// Migration safety: see scripts/migrate-to-v12.ts for the data migration that
// (a) creates the Greenreleaf tenant, (b) backfills tenantId on existing rows,
// (c) promotes the existing admin to also be SUPER_ADMIN, (d) sets W-4 defaults.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  ADMIN
  MANAGER
  LEAD
  EMPLOYEE
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum SwapStatus {
  OFFERED
  CLAIMED
  APPROVED
  DENIED
  CANCELED
}

enum EmploymentType {
  W2
  CONTRACTOR_1099
  UNSPECIFIED
}

enum FilingStatus {
  SINGLE
  MARRIED_JOINT
  MARRIED_SEPARATE
  HEAD_OF_HOUSEHOLD
}

enum PayPeriodStatus {
  DRAFT       // Period exists; paystubs may be regenerated
  FINALIZED   // Locked; paystubs are immutable
}

enum USState {
  AL
  AK
  AZ
  AR
  CA
  CO
  CT
  DE
  FL
  GA
  HI
  ID
  IL
  IN
  IA
  KS
  KY
  LA
  ME
  MD
  MA
  MI
  MN
  MS
  MO
  MT
  NE
  NV
  NH
  NJ
  NM
  NY
  NC
  ND
  OH
  OK
  OR
  PA
  RI
  SC
  SD
  TN
  TX
  UT
  VT
  VA
  WA
  WV
  WI
  WY
  DC
}

// ============================================================
// Tenant — top-level container for a business
// ============================================================

model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique  // URL subdomain, e.g. "greenreleaf" → greenreleaf.shiftwork.app
  businessName    String
  legalName       String?  // for tax forms; defaults to businessName
  state           USState
  addressLine1    String?
  addressLine2    String?
  city            String?
  zip             String?
  phone           String?
  federalEIN      String?  // 9 digits, no dash
  stateTaxId      String?  // KY withholding account number, etc.

  // Payroll config
  payFrequency    String   @default("BIWEEKLY")  // BIWEEKLY only for v12; future: WEEKLY, SEMI_MONTHLY, MONTHLY
  firstPeriodStart DateTime?  // anchor date for computing pay period boundaries

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  locations       Location[]
  shifts          Shift[]
  clockEntries    ClockEntry[]
  timeOff         TimeOffRequest[]
  swaps           ShiftSwap[]
  payPeriods     PayPeriod[]

  @@index([slug])
  @@index([active])
}

// ============================================================
// User
// ============================================================

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String

  // Tenant scoping
  // - SUPER_ADMIN users have tenantId = null (they don't belong to any tenant).
  // - All other users belong to exactly one tenant.
  tenantId     String?
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  superAdmin   Boolean      @default(false)

  role         Role         @default(EMPLOYEE)
  department   String?
  active       Boolean      @default(true)
  archivedAt   DateTime?
  hourlyWage   Float        @default(0)
  isTipped     Boolean      @default(false)

  // Profile (v5+)
  photoUrl                 String?  @db.Text
  phone                    String?
  address                  String?  @db.Text
  dateOfBirth              DateTime?
  hireDate                 DateTime?
  employmentType           EmploymentType @default(UNSPECIFIED)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  notes                    String?  @db.Text

  // Payroll / W-4 fields (NEW in v12)
  // Sourced from the employee's W-4 form (post-2020 design).
  // Defaults assume "Single, no other adjustments" — must be overridden per-employee
  // before payroll calculations are reliable.
  filingStatus           FilingStatus @default(SINGLE)
  multipleJobsCheckbox   Boolean      @default(false)  // W-4 step 2c
  dependentsCredit       Float        @default(0)      // W-4 step 3 (annual dollars, e.g. $2000 per qualifying child)
  otherIncome            Float        @default(0)      // W-4 step 4a (annual dollars)
  deductionsAdjustment   Float        @default(0)      // W-4 step 4b (annual dollars beyond standard deduction)
  extraWithholding       Float        @default(0)      // W-4 step 4c (per-pay-period dollars)

  // KY-specific (only set when tenant.state = KY; nullable otherwise)
  kyExemptionsAllowance  Int?         // KY DOR Form K-4

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  shifts          Shift[]            @relation("EmployeeShifts")
  createdShifts   Shift[]            @relation("ManagerShifts")
  clockEntries    ClockEntry[]
  locations       EmployeeLocation[]
  availability    Availability[]
  timeOff         TimeOffRequest[]   @relation("EmployeeTimeOff")
  decidedTimeOff  TimeOffRequest[]   @relation("ManagerTimeOff")
  offeredSwaps    ShiftSwap[]        @relation("OfferedSwaps")
  claimedSwaps    ShiftSwap[]        @relation("ClaimedSwaps")
  decidedSwaps    ShiftSwap[]        @relation("DecidedSwaps")
  resetTokens     PasswordReset[]
  payStubs        PayStub[]

  // Indexes for tenant scoping
  @@index([tenantId, active])
  @@index([tenantId, role])
  @@index([superAdmin])
}

// ============================================================
// Location
// ============================================================

model Location {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  timezone  String   @default("America/New_York")
  active    Boolean  @default(true)
  hours     Json?
  createdAt DateTime @default(now())

  shifts    Shift[]
  employees EmployeeLocation[]

  @@index([tenantId, active])
}

model EmployeeLocation {
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, locationId])
}

// ============================================================
// Shift
// ============================================================

model Shift {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    User     @relation("EmployeeShifts", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId   String
  manager     User     @relation("ManagerShifts", fields: [managerId], references: [id])
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
  startTime   DateTime
  endTime     DateTime
  role        String?
  notes       String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  reminderSent Boolean @default(false)
  createdAt   DateTime @default(now())

  swap        ShiftSwap?

  @@index([tenantId, startTime])
  @@index([employeeId, startTime])
  @@index([locationId, startTime])
  @@index([published, startTime])
}

// ============================================================
// ClockEntry
// ============================================================

model ClockEntry {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn     DateTime
  clockOut    DateTime?
  selfieIn    String?   @db.Text
  selfieOut   String?   @db.Text
  latIn       Float?
  lngIn       Float?
  latOut      Float?
  lngOut      Float?
  editedBy    String?
  editNote    String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, clockIn])
  @@index([userId, clockIn])
}

// ============================================================
// Availability — per-employee weekly availability
// (Inherits tenant scope via user; no direct tenantId needed since every
// availability row is owned by a single user that's already tenant-scoped.)
// ============================================================

model Availability {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId, dayOfWeek])
}

// ============================================================
// TimeOffRequest
// ============================================================

model TimeOffRequest {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation("EmployeeTimeOff", fields: [userId], references: [id], onDelete: Cascade)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       RequestStatus  @default(PENDING)
  decidedBy    String?
  decider      User?          @relation("ManagerTimeOff", fields: [decidedBy], references: [id])
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime       @default(now())

  @@index([tenantId, status])
  @@index([userId, startDate])
}

// ============================================================
// ShiftSwap
// ============================================================

model ShiftSwap {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shiftId      String     @unique
  shift        Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  offeredById  String
  offeredBy    User       @relation("OfferedSwaps", fields: [offeredById], references: [id])
  claimedById  String?
  claimedBy    User?      @relation("ClaimedSwaps", fields: [claimedById], references: [id])
  status       SwapStatus @default(OFFERED)
  decidedById  String?
  decidedBy    User?      @relation("DecidedSwaps", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  note         String?
  createdAt    DateTime   @default(now())

  @@index([tenantId, status])
}

// ============================================================
// PasswordReset (no tenant scoping needed; one-time tokens)
// ============================================================

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

// ============================================================
// PAYROLL — new in v12
// ============================================================

model PayPeriod {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodStart   DateTime        // Inclusive
  periodEnd     DateTime        // Inclusive
  payDate       DateTime        // Date employees are paid (typically a few days after periodEnd)
  status        PayPeriodStatus @default(DRAFT)
  finalizedAt   DateTime?
  finalizedBy   String?         // userId of admin who finalized
  notes         String?         @db.Text

  // Year-to-date snapshot AT the time of finalization (for accurate Additional Medicare,
  // Social Security wage cap enforcement, etc.). Nullable until finalized.
  ytdGrossSnapshotJson Json?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  payStubs      PayStub[]

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId, payDate])
  @@index([tenantId, status])
}

model PayStub {
  id              String    @id @default(cuid())
  payPeriodId     String
  payPeriod       PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Hours
  regularHours    Float     // <= 40 hrs per week summed across the pay period
  overtimeHours   Float     // > 40 hrs per week
  // Note: KY follows federal FLSA — OT is computed per workweek, not per pay period.

  // Pay
  hourlyRate      Float     // Snapshot at time of stub generation
  regularPay      Float
  overtimePay     Float
  grossPay        Float

  // Federal taxes
  federalIncomeTax        Float
  socialSecurityTax       Float
  medicareTax             Float
  additionalMedicareTax   Float    // 0 unless YTD wages > $200k

  // State taxes (KY)
  stateIncomeTax          Float

  // Local taxes (placeholder for future; 0 in v12)
  localIncomeTax          Float    @default(0)

  // Pre-tax deductions (placeholder for future; 0 in v12)
  preTaxDeductions        Float    @default(0)

  // Post-tax deductions
  extraWithholding        Float    // From W-4 step 4c

  totalDeductions         Float    // sum of all taxes + deductions
  netPay                  Float

  // Snapshot of W-4 settings at stub time (for audit / explanation)
  filingStatusSnapshot         FilingStatus
  multipleJobsCheckboxSnapshot Boolean
  dependentsCreditSnapshot     Float
  otherIncomeSnapshot          Float
  deductionsAdjustmentSnapshot Float

  // PDF storage (base64 or external URL — TBD; for v12 we generate on-demand, no storage)
  pdfUrl          String?   @db.Text

  generatedAt     DateTime  @default(now())

  // Optional notes / corrections
  notes           String?   @db.Text

  @@unique([payPeriodId, employeeId])
  @@index([employeeId, generatedAt])
}
