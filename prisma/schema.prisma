// TRANSITIONAL v12 schema. Used ONCE, between v11 and final v12 schema.
// Difference from final v12: tenantId is NULLABLE on Location, Shift, ClockEntry,
// TimeOffRequest, ShiftSwap. This lets `prisma db push` add the columns without
// failing on existing rows. The migration script then backfills tenantId, and a
// second `prisma db push` against the final schema enforces NOT NULL.
//
// Workflow:
//   1. cp schema.transitional.prisma schema.prisma
//   2. npx prisma db push          (adds columns + new tables, allows nulls)
//   3. npx tsx scripts/migrate-to-v12.ts  (backfills tenantId, creates super-admin)
//   4. cp schema.prisma.final schema.prisma  (FINAL v12 schema)
//   5. npx prisma db push          (enforces NOT NULL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  LEAD
  EMPLOYEE
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum SwapStatus {
  OFFERED
  CLAIMED
  APPROVED
  DENIED
  CANCELED
}

enum EmploymentType {
  W2
  CONTRACTOR_1099
  UNSPECIFIED
}

enum FilingStatus {
  SINGLE
  MARRIED_JOINT
  MARRIED_SEPARATE
  HEAD_OF_HOUSEHOLD
}

enum PayPeriodStatus {
  DRAFT
  FINALIZED
}

enum USState {
  AL
  AK
  AZ
  AR
  CA
  CO
  CT
  DE
  FL
  GA
  HI
  ID
  IL
  IN
  IA
  KS
  KY
  LA
  ME
  MD
  MA
  MI
  MN
  MS
  MO
  MT
  NE
  NV
  NH
  NJ
  NM
  NY
  NC
  ND
  OH
  OK
  OR
  PA
  RI
  SC
  SD
  TN
  TX
  UT
  VT
  VA
  WA
  WV
  WI
  WY
  DC
}

model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique
  businessName    String
  legalName       String?
  state           USState
  addressLine1    String?
  addressLine2    String?
  city            String?
  zip             String?
  phone           String?
  federalEIN      String?
  stateTaxId      String?
  payFrequency    String   @default("BIWEEKLY")
  firstPeriodStart DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  locations       Location[]
  shifts          Shift[]
  clockEntries    ClockEntry[]
  timeOff         TimeOffRequest[]
  swaps           ShiftSwap[]
  payPeriods      PayPeriod[]

  @@index([slug])
  @@index([active])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String

  // TRANSITIONAL: tenantId nullable to allow upgrade from v11
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  superAdmin   Boolean  @default(false)

  role         Role     @default(EMPLOYEE)
  department   String?
  active       Boolean  @default(true)
  archivedAt   DateTime?
  hourlyWage   Float    @default(0)
  isTipped     Boolean  @default(false)

  photoUrl                 String?  @db.Text
  phone                    String?
  address                  String?  @db.Text
  dateOfBirth              DateTime?
  hireDate                 DateTime?
  employmentType           EmploymentType @default(UNSPECIFIED)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  notes                    String?  @db.Text

  filingStatus           FilingStatus @default(SINGLE)
  multipleJobsCheckbox   Boolean      @default(false)
  dependentsCredit       Float        @default(0)
  otherIncome            Float        @default(0)
  deductionsAdjustment   Float        @default(0)
  extraWithholding       Float        @default(0)
  kyExemptionsAllowance  Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shifts          Shift[]            @relation("EmployeeShifts")
  createdShifts   Shift[]            @relation("ManagerShifts")
  clockEntries    ClockEntry[]
  locations       EmployeeLocation[]
  availability    Availability[]
  timeOff         TimeOffRequest[]   @relation("EmployeeTimeOff")
  decidedTimeOff  TimeOffRequest[]   @relation("ManagerTimeOff")
  offeredSwaps    ShiftSwap[]        @relation("OfferedSwaps")
  claimedSwaps    ShiftSwap[]        @relation("ClaimedSwaps")
  decidedSwaps    ShiftSwap[]        @relation("DecidedSwaps")
  resetTokens     PasswordReset[]
  payStubs        PayStub[]

  @@index([tenantId, active])
  @@index([tenantId, role])
  @@index([superAdmin])
}

model Location {
  id        String   @id @default(cuid())
  tenantId  String?  // TRANSITIONAL: nullable
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  timezone  String   @default("America/New_York")
  active    Boolean  @default(true)
  hours     Json?
  createdAt DateTime @default(now())

  shifts    Shift[]
  employees EmployeeLocation[]

  @@index([tenantId, active])
}

model EmployeeLocation {
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, locationId])
}

model Shift {
  id           String   @id @default(cuid())
  tenantId     String?  // TRANSITIONAL: nullable
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     User     @relation("EmployeeShifts", fields: [employeeId], references: [id], onDelete: Cascade)
  managerId    String
  manager      User     @relation("ManagerShifts", fields: [managerId], references: [id])
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  startTime    DateTime
  endTime      DateTime
  role         String?
  notes        String?
  published    Boolean  @default(false)
  publishedAt  DateTime?
  reminderSent Boolean  @default(false)
  createdAt    DateTime @default(now())

  swap         ShiftSwap?

  @@index([tenantId, startTime])
  @@index([employeeId, startTime])
  @@index([locationId, startTime])
  @@index([published, startTime])
}

model ClockEntry {
  id          String    @id @default(cuid())
  tenantId    String?   // TRANSITIONAL: nullable
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn     DateTime
  clockOut    DateTime?
  selfieIn    String?   @db.Text
  selfieOut   String?   @db.Text
  latIn       Float?
  lngIn       Float?
  latOut      Float?
  lngOut      Float?
  editedBy    String?
  editNote    String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, clockIn])
  @@index([userId, clockIn])
}

model Availability {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId, dayOfWeek])
}

model TimeOffRequest {
  id           String         @id @default(cuid())
  tenantId     String?        // TRANSITIONAL: nullable
  tenant       Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation("EmployeeTimeOff", fields: [userId], references: [id], onDelete: Cascade)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       RequestStatus  @default(PENDING)
  decidedBy    String?
  decider      User?          @relation("ManagerTimeOff", fields: [decidedBy], references: [id])
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime       @default(now())

  @@index([tenantId, status])
  @@index([userId, startDate])
}

model ShiftSwap {
  id           String     @id @default(cuid())
  tenantId     String?    // TRANSITIONAL: nullable
  tenant       Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shiftId      String     @unique
  shift        Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  offeredById  String
  offeredBy    User       @relation("OfferedSwaps", fields: [offeredById], references: [id])
  claimedById  String?
  claimedBy    User?      @relation("ClaimedSwaps", fields: [claimedById], references: [id])
  status       SwapStatus @default(OFFERED)
  decidedById  String?
  decidedBy    User?      @relation("DecidedSwaps", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  note         String?
  createdAt    DateTime   @default(now())

  @@index([tenantId, status])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

model PayPeriod {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  payDate       DateTime
  status        PayPeriodStatus @default(DRAFT)
  finalizedAt   DateTime?
  finalizedBy   String?
  notes         String?         @db.Text
  ytdGrossSnapshotJson Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  payStubs      PayStub[]

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId, payDate])
  @@index([tenantId, status])
}

model PayStub {
  id              String    @id @default(cuid())
  payPeriodId     String
  payPeriod       PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  regularHours    Float
  overtimeHours   Float
  hourlyRate      Float
  regularPay      Float
  overtimePay     Float
  grossPay        Float

  federalIncomeTax        Float
  socialSecurityTax       Float
  medicareTax             Float
  additionalMedicareTax   Float

  stateIncomeTax          Float
  localIncomeTax          Float    @default(0)
  preTaxDeductions        Float    @default(0)
  extraWithholding        Float
  totalDeductions         Float
  netPay                  Float

  filingStatusSnapshot         FilingStatus
  multipleJobsCheckboxSnapshot Boolean
  dependentsCreditSnapshot     Float
  otherIncomeSnapshot          Float
  deductionsAdjustmentSnapshot Float

  pdfUrl          String?   @db.Text
  generatedAt     DateTime  @default(now())
  notes           String?   @db.Text

  @@unique([payPeriodId, employeeId])
  @@index([employeeId, generatedAt])
}
