# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Resend (for emails: password reset, schedule publish, shift reminders)
# Sign up at https://resend.com — free tier is 3000 emails/month
# Leave RESEND_API_KEY empty to disable emails (password reset won't work)
RESEND_API_KEY=""
# The "from" address for outbound mail. Must match a verified domain on Resend,
# or use the sandbox address: onboarding@resend.dev
EMAIL_FROM="Shiftwork <onboarding@resend.dev>"

# Cron secret - any long random string. Vercel calls cron endpoints with this.
CRON_SECRET="replace-with-another-long-random-string"
